BEGIN

a := 10;
b := 20;
c := 30;
d := 40;
e := true;
f := true;


write(1  * (( (a) = (b) ) = 0));
write(2  * (( (a * b) + c ) = 230));
write(3  * (( a * b + c ) = 230));
write(4  * (( a*(b+c) ) = 500));
write(5  * (( (a+b) > c ) = 0));
write(6  * (( a + b > c ) = 0));
write(7  * (( a+(b>c) ) = 10));
write(8  * (( a + b > c ) = 0));
write(9  * (( (a > b) = (b > c) ) != 1));
write(10 * (( a > b = b > c ) = 1));
write(11 * (( (a = b) > (b = c) ) = 0));
write(12 * (( (a != b) && (c <= d) ) = 1));
write(13 * (( a != b && c <= d ) = 1));
write(14 * (( (a > b) && (c || d) ) = 0));
write(15 * (( a > b && c || d ) = 1));
write(16 * (( (a = b) && c ) = 0));
write(17 * (( a = b && c ) = 0));
write(18 * (( !(a+b) || !(b+1 | 1 + c) ) = 0));
write(19 * (( (a - (b | d) | b & c | d | c + d & a) ) = -2));
write(20 * (( (true & true) ) = 1));
write(21 * (( (!(a <= b) || c > 4) ) = 1));
write(22 * (( (!a | 8 || b + 5) ) = 1));
write(23 * (( !(a && b) && (!1 || b) && (!b || b) ) = 0));
write(123 * (( ((e = e) = f) & -10 ) = 0)) /*???*/

